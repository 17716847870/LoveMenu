generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String            @id @default(cuid())
  username     String            @unique
  password     String
  name         String
  email        String?           @unique
  avatar       String?
  role         String            @default("user")
  kissBalance  Int               @default(100)
  hugBalance   Int               @default(100)
  createdAt    DateTime          @default(now())
  cartItems    CartItem[]
  chat         ChatMessage[]     @relation("ChatSender")
  chatReads    ChatMessageRead[]
  orders       Order[]
  favorites    DishFavorite[]
}

model DishCategory {
  id        String @id @default(cuid())
  name      String
  sortOrder Int
  dishes    Dish[]
}

model Dish {
  id              String       @id @default(cuid())
  name            String
  description     String
  categoryId      String
  kissPrice       Int
  hugPrice        Int
  image           String?
  popularity      Int          @default(0)
  allowCook       Boolean      @default(true)
  allowRestaurant Boolean      @default(true)
  createdAt       DateTime     @default(now())
  cartItems       CartItem[]
  category        DishCategory @relation(fields: [categoryId], references: [id])
  orderItems      OrderItem[]
  favorites       DishFavorite[]
}

model Order {
  id          String         @id @default(cuid())
  userId      String
  status      String
  totalKiss   Int
  totalHug    Int
  note        String?
  reason      String?
  isEmergency Boolean        @default(false)
  createdAt   DateTime       @default(now())
  user        User           @relation(fields: [userId], references: [id])
  feedback    OrderFeedback?
  items       OrderItem[]
}

model OrderItem {
  id       String  @id @default(cuid())
  orderId  String
  dishId   String
  quantity Int
  note     String?
  dish     Dish    @relation(fields: [dishId], references: [id])
  order    Order   @relation(fields: [orderId], references: [id])
}

model CartItem {
  id       String @id @default(cuid())
  userId   String
  dishId   String
  quantity Int
  dish     Dish   @relation(fields: [dishId], references: [id])
  user     User   @relation(fields: [userId], references: [id])
}

model DishFavorite {
  id        String   @id @default(cuid())
  userId    String
  dishId    String
  createdAt DateTime @default(now())
  dish      Dish     @relation(fields: [dishId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dishId])
  @@index([userId])
  @@index([dishId])
}

model FoodRequest {
  id          String   @id @default(cuid())
  name        String
  description String
  image       String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
}

model UrgentRequest {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
}

model Feedback {
  id        String   @id @default(cuid())
  type      String
  title     String
  content   String
  image     String?
  status    String   @default("open")
  createdAt DateTime @default(now())
}

model OrderFeedback {
  id        String   @id @default(cuid())
  orderId   String   @unique
  text      String
  image     String?
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id])
}

model ChatMessage {
  id        String            @id @default(cuid())
  senderId  String
  type      String
  content   String
  createdAt DateTime          @default(now())
  sender    User              @relation("ChatSender", fields: [senderId], references: [id])
  reads     ChatMessageRead[]
}

model ChatMessageRead {
  id        String      @id @default(cuid())
  messageId String
  userId    String
  createdAt DateTime    @default(now())
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
  @@index([messageId])
}

model SystemConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

// 纪念日提醒
model Anniversary {
  id             String           @id @default(cuid())
  title          String           // 纪念日标题
  calendarType   String           // "solar" | "lunar"
  month          Int              // 月（国历直接用，农历存农历月）
  day            Int              // 日（国历直接用，农历存农历日）
  weekday        Int?             // 仅 repeatType=weekly 时使用，0=周日 1=周一 ... 6=周六
  repeatType     String           // "once" | "weekly" | "monthly" | "quarterly" | "halfyear" | "yearly"
  advanceDays    Int              @default(0) // 提前几天提醒，0=当天
  emailTo        String           // 收件邮箱
  emailSubject   String           // 邮件主题
  emailContent   String           // 邮件正文（支持模板变量）
  status         String           @default("active") // "active" | "paused" | "done"
  nextRemindAt   DateTime?        // 下一次提醒的公历时间（早上10点北京时间）
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  logs           AnniversaryLog[]
}

// 纪念日发送历史
model AnniversaryLog {
  id             String       @id @default(cuid())
  anniversaryId  String
  sentAt         DateTime     @default(now())
  emailTo        String
  status         String       // "success" | "failed"
  error          String?      // 失败原因
  anniversary    Anniversary  @relation(fields: [anniversaryId], references: [id], onDelete: Cascade)

  @@index([anniversaryId])
}
